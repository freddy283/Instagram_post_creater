# ─── Required ─────────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=your-random-secret-key-here
DATABASE_URL=sqlite:///./dailyquote.db

# ─── FREE Script Generation (pick ONE — both optional) ────────────────────────
# Groq — FREE tier, no credit card. Sign up at console.groq.com (takes 2 min)
# Uses LLaMA-3.3-70b — excellent quality, generous free rate limits
GROQ_API_KEY=gsk_...

# OpenAI — only if you already have a key (optional)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ─── FREE Backgrounds (Pixabay) ───────────────────────────────────────────────
# Sign up FREE at pixabay.com/api/docs — no credit card, instant approval
# Gives you beautiful real photographs as video backgrounds
PIXABAY_API_KEY=...

# ─── FREE TTS (edge-tts) ──────────────────────────────────────────────────────
# No key needed! edge-tts uses Microsoft's servers for free.
# Just install: pip install edge-tts
# Fallback: pyttsx3 (offline) → ambient tone (no install needed)

# ─── Video / Brand settings ───────────────────────────────────────────────────
VIDEO_THEME=success, growth and daily motivation
BRAND_HANDLE=@your_brand
VIDEOS_DIR=./videos

# ─── Instagram Auto-posting (optional) ───────────────────────────────────────
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_REDIRECT_URI=http://localhost:8000/api/instagram/callback
PUBLIC_URL=http://localhost:8000

# ─── Celery / Redis ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
